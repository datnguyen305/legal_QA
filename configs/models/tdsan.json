{
  "model": "tdsan",
  "paper": "Token-level Dynamic Self-Attention Network for Multi-Passage Reading Comprehension",
  "entrypoints": {
    "pipeline": "scripts/pipelines/run_tdsan_pipeline.sh",
    "train": "scripts/train_tdsan.py",
    "predict": "scripts/run_tdsan.py"
  },
  "data": {
    "train_data": "dataset/train_data.json",
    "dev_data": "dataset/dev_data.json",
    "test_data": "dataset/test_data.json",
    "context_dir": "dataset/contexts"
  },
  "paths": {
    "model_dir": "models/tdsan",
    "output_dir": "outputs",
    "predictions": "outputs/tdsan.jsonl",
    "metrics": "outputs/tdsan_metrics.json"
  },
  "train": {
    "batch_size": 8,
    "epochs": 25,
    "learning_rate": 1e-3,
    "max_passages": 4,
    "max_context_chars": 12000,
    "max_question_tokens": 96,
    "max_passage_tokens": 1536,
    "hidden": 128,
    "heads": 8,
    "top_k": 256,
    "train_limit": null,
    "dev_limit": null,
    "device": null,
    "skip_train": false
  },
  "predict": {
    "limit": null
  },
  "evaluation": {
    "upper_bound": false
  }
}
