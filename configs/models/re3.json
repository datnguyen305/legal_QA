{
  "model": "re3",
  "paper": "Retrieve, Read, Rerank: Towards End-to-End Multi-Document Reading Comprehension",
  "entrypoints": {
    "pipeline": "scripts/pipelines/run_re3_pipeline.sh",
    "train": "scripts/train_re3.py",
    "predict": "scripts/run_re3.py"
  },
  "data": {
    "train_data": "dataset/train_data.json",
    "dev_data": "dataset/dev_data.json",
    "test_data": "dataset/test_data.json",
    "context_dir": "dataset/contexts"
  },
  "paths": {
    "model_dir": "models/re3",
    "output_dir": "outputs",
    "predictions": "outputs/re3.jsonl",
    "metrics": "outputs/re3_metrics.json"
  },
  "train": {
    "base_model": "bert-base-multilingual-cased",
    "batch_size": 4,
    "epochs": 2,
    "learning_rate": 3e-5,
    "window_tokens": 320,
    "stride": 128,
    "max_context_chars": 12000,
    "max_length": 384,
    "early_layer": 3,
    "max_candidates": 5,
    "train_limit": null,
    "dev_limit": null,
    "device": null,
    "skip_train": false
  },
  "predict": {
    "limit": null
  },
  "evaluation": {
    "upper_bound": false
  }
}
