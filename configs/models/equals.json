{
  "model": "equals",
  "paper": "EQUALS",
  "entrypoints": {
    "pipeline": "scripts/pipelines/run_equals_pipeline.sh",
    "train": "scripts/train_equals_mrc.py",
    "predict": "scripts/run_equals.py"
  },
  "data": {
    "train_data": "dataset/train_data.json",
    "dev_data": "dataset/dev_data.json",
    "test_data": "dataset/test_data.json",
    "context_dir": "dataset/contexts"
  },
  "paths": {
    "model_dir": "models/equals_mrc",
    "output_dir": "outputs"
  },
  "train": {
    "base_model": "bert-base-multilingual-cased",
    "batch_size": 4,
    "epochs": 2,
    "learning_rate": 2e-5,
    "max_context_chars": 12000,
    "max_length": 512,
    "train_limit": null,
    "dev_limit": null,
    "device": null,
    "num_workers": 4,
    "preprocess_num_proc": 4,
    "skip_train": false
  },
  "predict": {
    "retriever": "gold",
    "sbert_model": "sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2",
    "top_k": 1,
    "max_answer_length": 261,
    "limit": null
  },
  "evaluation": {
    "upper_bound": false
  }
}
