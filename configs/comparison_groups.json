{
  "purpose": "Fair comparison groups for Legal QA experiments. Compare models inside the same group first; cross-group comparisons should be marked as contextual, not direct.",
  "global_controls": {
    "same_split": [
      "dataset/train_data.json",
      "dataset/dev_data.json",
      "dataset/test_data.json"
    ],
    "same_context_dir": "dataset/contexts",
    "prediction_mode_default": true,
    "upper_bound_mode_is_oracle_only": true,
    "recommended_smoke_limits": {
      "train_limit": 1000,
      "dev_limit": 200,
      "test_limit": 100
    }
  },
  "groups": [
    {
      "id": "pretrained_extractive_reader",
      "label": "Pretrained extractive readers",
      "fairness_rule": "Compare these directly when they use the same base model, max length, train/dev/test split, context slicing, and prediction-mode evaluation.",
      "models": [
        "equals",
        "fetsf_mrc",
        "sae",
        "re3"
      ],
      "shared_properties": {
        "uses_pretrained_transformer": true,
        "default_base_model": "bert-base-multilingual-cased",
        "answer_style": "extractive"
      }
    },
    {
      "id": "custom_neural_extractive_reader",
      "label": "Custom neural extractive readers trained from scratch",
      "fairness_rule": "Compare these separately from pretrained BERT-style systems because they do not receive pretrained language-model knowledge.",
      "models": [
        "tdsan",
        "deep_cascade"
      ],
      "shared_properties": {
        "uses_pretrained_transformer": false,
        "answer_style": "extractive"
      }
    },
    {
      "id": "custom_generative_reader",
      "label": "Custom generative readers trained from scratch",
      "fairness_rule": "Compare generative models separately from extractive span readers because they generate answer text instead of selecting spans.",
      "models": [
        "cpg"
      ],
      "shared_properties": {
        "uses_pretrained_transformer": false,
        "answer_style": "generative"
      }
    },
    {
      "id": "retrieval_pipeline",
      "label": "Retrieval plus reading pipelines",
      "fairness_rule": "Report retriever setting with every score. Gold/oracle context, BM25, SBERT, and learned retrieval are not directly equivalent.",
      "models": [
        "equals",
        "sae",
        "deep_cascade",
        "re3"
      ],
      "retrieval_settings": {
        "oracle_context": [
          "equals: RETRIEVER=gold"
        ],
        "lexical_retrieval": [
          "equals: RETRIEVER=bm25"
        ],
        "dense_retrieval": [
          "equals: RETRIEVER=sbert"
        ],
        "learned_or_model_internal_retrieval": [
          "sae",
          "deep_cascade",
          "re3"
        ]
      }
    },
    {
      "id": "oracle_and_sanity_checks",
      "label": "Oracle and sanity-check runs",
      "fairness_rule": "Do not rank these as model performance. Use them only to verify data loading, context access, and metric upper bounds.",
      "models": [
        "baseline:paper_gold",
        "evaluation:upper_bound"
      ],
      "shared_properties": {
        "uses_gold_answer_as_prediction": true
      }
    }
  ],
  "recommended_tables": [
    {
      "name": "main_fair_table_pretrained",
      "models": [
        "equals",
        "fetsf_mrc",
        "sae",
        "re3"
      ],
      "required_columns": [
        "model",
        "base_model",
        "retriever_or_context",
        "train_limit",
        "dev_limit",
        "test_limit",
        "rouge_l",
        "meteor",
        "cider"
      ]
    },
    {
      "name": "from_scratch_table",
      "models": [
        "tdsan",
        "deep_cascade",
        "cpg"
      ],
      "required_columns": [
        "model",
        "answer_style",
        "train_limit",
        "dev_limit",
        "test_limit",
        "rouge_l",
        "meteor",
        "cider"
      ]
    },
    {
      "name": "oracle_sanity_table",
      "models": [
        "baseline:paper_gold",
        "evaluation:upper_bound"
      ],
      "required_columns": [
        "run",
        "count",
        "rouge_l",
        "meteor",
        "cider"
      ]
    }
  ]
}
